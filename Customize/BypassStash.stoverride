    - "*.hzbank.com.cn"
    - "*.njcb.com.cn"
    - "*.njbank.com.cn"
    - "*.bocn.com"
    - "*.cqcbank.com"
    - "*.cqrcb.com"
    - "*.srcb.com"
    - "*.shrcb.com"
    - "*.cbhb.com.cn"
