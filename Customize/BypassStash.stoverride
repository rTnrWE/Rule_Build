    - "*.ys7cloud.com"
    - "*.open.ys7.com"

    # Other common CN services
    - "*.163.com"
    - "*.126.net"
    - "*.yeah.net"
    - "*.126.com"
    - "*.netease.com"
    - "*.163yun.com"
    - "*.xiaomi.com"
    - "*.miwifi.com"
    - "*.mi.com"
    - "*.xiaomi.net"
    - "*.jd.com"
    - "*.jd.hk"
    - "*.360buyimg.com"
    - "*.jcloud.com"
    - "*.bilibili.com"
    - "*.bilivideo.com"
    - "*.hdslb.com"
    - "*.meituan.com"
    - "*.dianping.com"
    - "*.sankuai.com"
    - "*.ele.me"
    - "*.didichuxing.com"
