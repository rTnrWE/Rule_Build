name: BypassStash
desc: Prevent common Chinese apps from entering Stash
date: 2026-03-15

dns:
  fake-ip-filter:
    # Local / LAN
    - localhost
    - "*.lan"
    - "*.local"
    - "*.arpa"

    # Time sync / connectivity
    - "time.*.com"
    - "ntp.*.com"
    - "*.ntp.org"
    - "*.msftncsi.com"
    - "*.msftconnecttest.com"

    # Apple
    - "*.apple.com"
    - "*.icloud.com"
    - "*.mzstatic.com"
    - "*.apple-dns.net"

    # Tencent / WeChat / QQ / WeCom / Tencent Office
    - "*.qq.com"
    - "*.qqmail.com"
    - "*.qzone.com"
    - "*.wechat.com"
    - "*.weixin.com"
    - "*.weiyun.com"
    - "*.weiyun.com.cn"
    - "*.foxmail.com"
    - "*.tim.qq.com"
    - "*.tenpay.com"
    - "*.wxutil.com"
    - "*.qpic.cn"
    - "*.gtimg.cn"
    - "*.gtimg.com"
    - "*.qlogo.cn"
    - "*.idqqimg.com"
    - "*.qcloud.com"
    - "*.myqcloud.com"
    - "*.tencent.com"
    - "*.tencent-cloud.com"
    - "*.docs.qq.com"
    - "*.meeting.tencent.com"
    - "*.voovmeeting.com"
    - "*.wecom.qq.com"
    - "*.work.weixin.qq.com"

    # Alibaba / Alipay / DingTalk / Amap / Ali Cloud
    - "*.alipay.com"
    - "*.alipayobjects.com"
    - "*.aliyun.com"
    - "*.aliyuncs.com"
    - "*.alicdn.com"
    - "*.taobao.com"
    - "*.tmall.com"
    - "*.tb.cn"
    - "*.1688.com"
    - "*.alibaba.com"
    - "*.amap.com"
    - "*.amap.com.cn"
    - "*.amapauto.com"
    - "*.autonavi.com"
    - "*.a-map.com"
    - "*.dingtalk.com"
    - "*.dingtalkapps.com"
    - "*.alimei.com"
    - "*.teambition.com"
    - "*.yuque.com"

    # ByteDance / Feishu / Lark / Douyin
    - "*.bytedance.com"
    - "*.byted.org"
    - "*.byteimg.com"
    - "*.ibytedtos.com"
    - "*.zijieapi.com"
    - "*.feishu.cn"
    - "*.feishucdn.com"
    - "*.feishu.net"
    - "*.larksuite.com"
    - "*.larksuitecdn.com"
    - "*.douyin.com"
    - "*.douyincdn.com"
    - "*.douyinpic.com"
    - "*.ixigua.com"
    - "*.toutiao.com"
    - "*.snssdk.com"

    # Baidu / Baidu Map / Netdisk
    - "*.baidu.com"
    - "*.baidubce.com"
    - "*.bdimg.com"
    - "*.bdstatic.com"
    - "*.baidupcs.com"
    - "*.pcs.baidu.com"
    - "*.map.baidu.com"
    - "*.dueros.baidu.com"

    # Navigation related
    - "*.mapbar.com"
    - "*.navinfo.com"
    - "*.navinfo.com.cn"

    # UnionPay / payment
    - "*.unionpay.com"
    - "*.unionpayintl.com"
    - "*.95516.com"
    - "*.chinaunionpay.com"
    - "*.yeepay.com"
    - "*.yeepaycdn.com"
    - "*.lianlianpay.com"
