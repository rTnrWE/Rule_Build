    - "*.gtja.com"
    - "*.cmschina.com"
    - "*.guosen.com.cn"
    - "*.gf.com.cn"
    - "*.cgws.com"
    - "*.zxwt.com.cn"
    - "*.swhygh.com"
    - "*.hongyuanhzt.com"
    - "*.cicc.com"
    - "*.citics.com"
    - "*.futunn.com"
    - "*.futuq.com"
    - "*.futuhk.com"
    - "*.moomoo.com"

    # Office / collaboration
    - "*.wps.cn"
    - "*.wpscdn.cn"
    - "*.kdocs.cn"
    - "*.kingsoft.com"
    - "*.yunzhijia.com"
    - "*.lanxin.cn"
    - "*.yonyou.com"
    - "*.seeyon.com"
    - "*.tongda2000.com"
    - "*.weaver.com.cn"

    # Hikvision / EZVIZ
    - "*.hikvision.com"
    - "*.hik-connect.com"
    - "*.hikvisioneurope.com"
    - "*.hikvisionlife.com"
    - "*.ezviz.com"
    - "*.ezvizlife.com"
